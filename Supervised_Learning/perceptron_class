class Perceptron(object):
    def __init__(self, eta=0.01, epochs=10):
        self.eta = eta
        self.epochs = epochs

    def train(self, X, y):
        # Initialize weights with small random numbers
        # +1 for the bias unit
        self.w_ = np.random.rand(1 + X.shape[1])
        self.errors_ = []

        for _ in range(self.epochs):
            errors = 0
            for xi, target in zip(X, y):
                # Calculate the update amount for weights
                # update = learning_rate * (predicted_output - actual_output)
                update = self.eta * (target - self.predict(xi))
                # Update weights (excluding bias)
                self.w_[:-1] += update * xi
                # Update bias weight
                self.w_[-1] += update
                # Count misclassifications
                errors += int(update != 0.0)
            self.errors_.append(errors)
            # If no errors, the model has converged
            if errors == 0:
                break
        return self

    def net_input(self, X):
        # Calculate the net input: dot product of features and weights + bias
        return np.dot(X, self.w_[:-1]) + self.w_[-1]

    def predict(self, X):
        # Predict class label based on the sign of the net input
        # 1 if net_input >= 0, -1 otherwise
        return np.where(self.net_input(X) >= 0.0, 1, -1)
